{
    "layer": "top",
    "position": "top",
    "height": 40,
    "spacing": 5,

    "modules-left": ["hyprland/workspaces", "custom/spacer", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "custom/nixos", "memory", "wireplumber", "battery", "backlight", "custom/exit"],

    "hyprland/workspaces": {
        "disable-scroll": true,
        "format": "{icon}",
        "format-icons": {
            "1": "ΌζΖ",
            "2": "ΌκΔ",
            "3": "ΎΕι",
            "4": "≤░ΙΙ",
            "5": "≤░ΙΚ",
            "6": "≤░Ξ╣",
            "7": "≤░Ξ╣"
        },
        "on-click": "activate"
    },

    "custom/spacer": {
        "format": "   "
    },

    "hyprland/window": {
        "max-length": 40,
        "icon": false,
        "format": "{}",
        "rewrite": {
            "Mozilla Firefox": "ΌζΖ firefox",
            "(.*) έΑΦ Mozilla Firefox": "ΌζΖ $1",
            "(.*) - Chromium": "ΌυΒ $1",
            "(vim|nvim).*": "ΌθΖ $0",
            "docker.*": "≤░κρ $0 $1",
            "(lf|lfcd)": "≤░βΖ $0",
            "(top|htop|bashtop)": "≤▒Ο┤ $0",
            "(bash|zsh)": "ΌςΖ $0",
            "intellij - (.*)": "Όη╡ $1"
        }
    },

    "clock": {
        "format": "{0:%R} ΎΒ│ {0:%m-%d}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>"
    },

    "wireplumber": {
        "format": "{icon}  {volume}%",
        "format-icons": ["ΎΑο", "ΎΑπ", "ΎΑρ"],
        "max-volume": 100,
        "on-click": "swaync-client -t -sw",
        "tooltip": false
    },

    "battery": {
        "bat": "BAT0",
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-icons": {
            "charging": ["≤░λθ", "≤░λε", "≤░ΓΗ", "≤░ΓΘ", "≤░ΓΙ", "≤░λζ", "≤░ΓΚ", "≤░λη", "≤░ΓΛ", "≤░ΓΜ", "≤░ΓΖ"],
            "default": ["≤▒ΔΞ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΒ", "≤░Β╣"]
        },
        "max-length": 25
    },

    "backlight": {
        "format": "≤░Δι  {percent}%"
    },

    "memory": {
        "interval": 30,
        "format": "ΎΦη  {used:0.1f}G"
    },

    "custom/exit": {
        "format": "ΎΑΣ",
        "on-click": "wlogout -b 5 -T 400 -B 400"
    },

    "tray": {
        "icon-size": 22,
        "spacing": 16
    }

    "custom/nixos": {
        "tooltip": true,
        "return-type": "json",
        "exec": "bash ~/nixconf/dotfiles/scripts/nixos_status.sh",
        "interval": 3600
    }
}
